PORT=3000
DB_PATH=data/obx.sqlite

# Structured logging for Grafana Loki via stdout.
# LOG_FORMAT defaults to json when unset. `bun run dev` sets pretty automatically.
SERVICE_NAME=obx-conditions
LOG_LEVEL=debug
# LOG_FORMAT=pretty

# Optional. WeatherSTEM requires an API key for full sensor access.
# Without this, the dashboard uses the public Currituck WeatherSTEM portal
# temperature and NWS point forecast/observations for the fire station area.
WEATHERSTEM_API_KEY=
